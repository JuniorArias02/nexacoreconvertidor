{
  "name": "nexa-core-services",
  "version": "1.0.0",
  "description": "Microservicio para conversión de documentos (Excel a PDF)",
  "main": "src/servidor.js",
  "type": "module",
  "scripts": {
    "start": "node src/servidor.js",
    "dev": "node --watch src/servidor.js",
    "token:list": "node src/Compartido/Infraestructura/Comandos/GestorTokensCLI.js list",
    "token:generate": "node src/Compartido/Infraestructura/Comandos/GestorTokensCLI.js generate",
    "token:delete": "node src/Compartido/Infraestructura/Comandos/GestorTokensCLI.js delete",
    "config:port": "node src/Compartido/Infraestructura/Comandos/GestorConfigCLI.js port set",
    "cors:list": "node src/Compartido/Infraestructura/Comandos/GestorConfigCLI.js cors list",
    "cors:add": "node src/Compartido/Infraestructura/Comandos/GestorConfigCLI.js cors add",
    "cors:remove": "node src/Compartido/Infraestructura/Comandos/GestorConfigCLI.js cors remove"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "libreoffice-convert": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  }
}
